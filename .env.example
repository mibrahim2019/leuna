# =============================================================================
# Leuna — Environment configuration template
# Copy to `.env` (never commit `.env`; it is gitignored) and fill in real values.
# Stack: Railway (hosting) · Supabase (PostgreSQL + S3 storage) · Resend (email)
# =============================================================================

# ----- Core app -----------------------------------------------------------
PORT=3000
# Public URL of the deployment (Railway service domain or your custom domain)
NEXT_PUBLIC_WEBAPP_URL="https://app.leuna.app"
# Internal URL used for server->server calls (usually same as above on Railway)
NEXT_PRIVATE_INTERNAL_WEBAPP_URL="https://app.leuna.app"

# Secrets — generate each with:  openssl rand -hex 32
NEXTAUTH_SECRET="REPLACE_ME"
NEXT_PRIVATE_ENCRYPTION_KEY="REPLACE_ME"
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY="REPLACE_ME"

# ----- AGPL §13 source availability (legal requirement) -------------------
# These power the in-app "Open Source" page that links to your published source.
NEXT_PUBLIC_SOURCE_CODE_URL="https://github.com/mibrahim2019/leuna"
# Set on each deploy to the exact commit being run (Railway: $RAILWAY_GIT_COMMIT_SHA)
NEXT_PUBLIC_SOURCE_CODE_REVISION="main"
NEXT_PUBLIC_SOURCE_CODE_REVISION_URL="https://github.com/mibrahim2019/leuna/tree/main"

# ----- Database (Supabase Postgres) ---------------------------------------
# Use the POOLED connection string (port 6543, pgbouncer) for the app:
NEXT_PRIVATE_DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the DIRECT connection string (port 5432) for migrations:
NEXT_PRIVATE_DIRECT_DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ----- Email (Resend) -----------------------------------------------------
NEXT_PRIVATE_SMTP_TRANSPORT="resend"
NEXT_PRIVATE_RESEND_API_KEY="re_REPLACE_ME"
# Must be a domain you have verified in Resend:
NEXT_PRIVATE_SMTP_FROM_ADDRESS="noreply@leuna.app"
NEXT_PRIVATE_SMTP_FROM_NAME="Leuna"

# ----- File storage (Supabase Storage — S3-compatible) --------------------
NEXT_PUBLIC_UPLOAD_TRANSPORT="s3"
NEXT_PRIVATE_UPLOAD_ENDPOINT="https://PROJECT.supabase.co/storage/v1/s3"
NEXT_PRIVATE_UPLOAD_REGION="us-east-1"
NEXT_PRIVATE_UPLOAD_BUCKET="documents"
NEXT_PRIVATE_UPLOAD_FORCE_PATH_STYLE="true"
NEXT_PRIVATE_UPLOAD_ACCESS_KEY_ID="REPLACE_ME"       # Supabase Storage S3 access key
NEXT_PRIVATE_UPLOAD_SECRET_ACCESS_KEY="REPLACE_ME"   # Supabase Storage S3 secret

# ----- Document signing certificate (REQUIRED, production) ----------------
# The dev cert in the repo is NOT valid for production. Generate/obtain a real
# P12 certificate, then provide it as base64 contents (preferred on Railway):
#   base64 -i your-cert.p12 | tr -d '\n'
NEXT_PRIVATE_SIGNING_TRANSPORT="local"
NEXT_PRIVATE_SIGNING_LOCAL_FILE_CONTENTS="REPLACE_ME_BASE64_P12"
NEXT_PRIVATE_SIGNING_LOCAL_FILE_ENCODING="base64"
NEXT_PRIVATE_SIGNING_PASSPHRASE=""

# ----- Background jobs ----------------------------------------------------
# Recommended on Railway: add a Redis service and use bullmq.
NEXT_PRIVATE_JOBS_PROVIDER="bullmq"
NEXT_PRIVATE_REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# ----- Optional: signups / auth providers ---------------------------------
# NEXT_PUBLIC_DISABLE_SIGNUP="false"
# NEXT_PRIVATE_GOOGLE_CLIENT_ID=""
# NEXT_PRIVATE_GOOGLE_CLIENT_SECRET=""

# ----- Telemetry (leave UNSET to keep OFF) --------------------------------
# Telemetry is a no-op unless both a key and host are configured. Do NOT set
# these unless you intend to run your OWN analytics endpoint.
# NEXT_PUBLIC_POSTHOG_KEY=""
